{
  "entities": {
    "Post": {
      "title": "Portfolio Post",
      "description": "A portfolio project display post, mimicking a Facebook post",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the project" },
        "description": { "type": "string", "description": "Text description of the project" },
        "imageUrl": { "type": "string", "description": "Image URL or background styled visual representing the project" },
        "tags": { "type": "array", "description": "Tech stack tags" },
        "likesCount": { "type": "integer", "description": "Number of reactions/likes" },
        "likedBy": { "type": "array", "description": "Array of visitor IDs who have liked this post" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["title", "description", "tags", "likesCount", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a project post",
      "type": "object",
      "properties": {
        "author": { "type": "string", "description": "DisplayName or name of the commenter" },
        "text": { "type": "string", "description": "Content of the comment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of comment" }
      },
      "required": ["author", "text", "createdAt"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "A logging record of a custom visitor profile on the portfolio",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Greeting or nickname of visitor" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of logging" }
      },
      "required": ["name", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Developer profile setting including stats and social links",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the developer" },
        "role": { "type": "string", "description": "Current title or role" },
        "company": { "type": "string", "description": "Company or current association" },
        "location": { "type": "string", "description": "Geographic location" },
        "bio": { "type": "string", "description": "Short description header" },
        "avatar": { "type": "string", "description": "Profile picture URL" },
        "coverPhoto": { "type": "string", "description": "Cover banner image URL" },
        "github": { "type": "string", "description": "Github profile URL Link" },
        "linkedin": { "type": "string", "description": "Linkedin profile URL Link" },
        "facebook": { "type": "string", "description": "Facebook profile URL Link" },
        "email": { "type": "string", "description": "Email mailto link" },
        "skills": { "type": "array", "description": "Core tech-stack skills list" }
      },
      "required": ["name", "skills"]
    }
  },
  "firestore": {
    "posts": {
      "schema": "Post",
      "description": "Chronological portfolio project posts"
    },
    "posts/{postId}/comments": {
      "schema": "Comment",
      "description": "Comments left by visitors on a specific post"
    },
    "visitors": {
      "schema": "Visitor",
      "description": "Logged visitor profiles with chronological order"
    },
    "profiles": {
      "schema": "UserProfile",
      "description": "Customizable developer profile settings synced across devices"
    }
  }
}
