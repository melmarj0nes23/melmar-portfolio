rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Post
    function isValidPost(data) {
      return (!data.keys().hasAll(['title']) || (data.title is string && data.title.size() <= 150))
        && (!data.keys().hasAll(['description']) || (data.description is string && data.description.size() <= 5000))
        && (!data.keys().hasAll(['tags']) || (data.tags is list && data.tags.size() <= 20))
        && (!data.keys().hasAll(['likesCount']) || (data.likesCount is int && data.likesCount >= 0))
        && (!data.keys().hasAll(['likedBy']) || (data.likedBy is list && data.likedBy.size() <= 2000))
        && (!data.keys().hasAll(['imageUrl']) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 2000))
        && (!data.keys().hasAll(['imageUrls']) || (data.imageUrls is list && data.imageUrls.size() <= 20 && (data.imageUrls.size() == 0 || data.imageUrls[0] is string)));
    }

    // Validation for Comment
    function isValidComment(data) {
      return (!data.keys().hasAll(['author']) || (data.author is string && data.author.size() <= 100))
        && (!data.keys().hasAll(['text']) || (data.text is string && data.text.size() <= 2000));
    }

    // Validation for Visitor
    function isValidVisitor(data) {
      return (!data.keys().hasAll(['name']) || (data.name is string && data.name.size() <= 100))
        && (!data.keys().hasAll(['createdAt']) || data.createdAt != null);
    }

    // Validation for UserProfile
    function isValidProfile(data) {
      return (!('name' in data) || (data.name is string && data.name.size() <= 150))
        && (!('role' in data) || (data.role is string && data.role.size() <= 200))
        && (!('company' in data) || (data.company is string && data.company.size() <= 250))
        && (!('location' in data) || (data.location is string && data.location.size() <= 200))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000))
        && (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 2500))
        && (!('coverPhoto' in data) || (data.coverPhoto is string && data.coverPhoto.size() <= 2500))
        && (!('github' in data) || (data.github is string && data.github.size() <= 1500))
        && (!('linkedin' in data) || (data.linkedin is string && data.linkedin.size() <= 1500))
        && (!('facebook' in data) || (data.facebook is string && data.facebook.size() <= 1500))
        && (!('email' in data) || (data.email is string && data.email.size() <= 1500))
        && (!('skills' in data) || (data.skills is list && data.skills.size() <= 50));
    }

    // Match rules for Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidPost(incoming())
        && incoming().keys().hasAll(['title', 'description', 'tags', 'likesCount', 'likedBy', 'createdAt'])
        && incoming().keys().size() >= 6 && incoming().keys().size() <= 8;
      allow update: if isValidId(postId) && isValidPost(incoming());
      allow delete: if true;
    }

    // Match rules for Comments subcollection
    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidId(commentId) && isValidComment(incoming());
      allow update, delete: if true;
    }

    // Match rules for Visitors collection
    match /visitors/{visitorId} {
      allow read, list: if true;
      allow create, update: if isValidId(visitorId) && isValidVisitor(incoming());
      allow delete: if false;
    }

    // Match rules for Profile collection (shared/synced across devices)
    match /profiles/{profileId} {
      allow read, get: if true;
      allow create, update: if isValidId(profileId) && isValidProfile(incoming());
      allow delete: if false;
    }
  }
}
